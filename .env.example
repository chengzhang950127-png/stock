# ===========================================
# quant-system — environment template
# Copy to .env and fill in real values for local dev.
# .env is gitignored. NEVER commit real secrets.
# ===========================================

# --- Application ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant_dev

# --- LLM Gateway ---
# Provider: "mock" (default for V0.1-V0.5) | "openrouter" | "openai" | "anthropic"
LLM_PROVIDER=mock
# Always pin a dated model id (no `latest` aliases — see INVARIANT #4)
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# --- Data sources ---
YFINANCE_RATE_LIMIT=2
TUSHARE_TOKEN=

# --- JWT (V0.7+) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# --- Notifications (V0.4+) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
